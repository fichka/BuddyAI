{
  "expo": {
    "name": "IELTS Buddy AI",
    "slug": "ielts-buddy-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "ielts-buddy-ai",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      }
    }
  }
}
